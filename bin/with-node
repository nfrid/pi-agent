#!/usr/bin/env bash
set -euo pipefail

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"

if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck source=/dev/null
  . "$NVM_DIR/nvm.sh"
else
  echo "with-node: nvm not found at $NVM_DIR/nvm.sh" >&2
  exit 127
fi

if [ -f .nvmrc ]; then
  nvm use >/dev/null || nvm install
elif [ -f .node-version ]; then
  nvm use "$(cat .node-version)" >/dev/null || nvm install "$(cat .node-version)"
fi

exec "$@"
